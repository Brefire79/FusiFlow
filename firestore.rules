rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function userRole() {
      return signedIn() && userDoc(request.auth.uid).exists
        ? userDoc(request.auth.uid).data.role
        : null;
    }

    function isAdmin() {
      return signedIn() && userRole() == "admin";
    }

    function projectDoc(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId));
    }

    function projectExists(projectId) {
      return projectDoc(projectId).exists;
    }

    function isProjectMember(projectId) {
      return signedIn()
        && projectExists(projectId)
        && projectDoc(projectId).data.members[request.auth.uid] != null;
    }

    function memberRole(projectId) {
      return isProjectMember(projectId)
        ? projectDoc(projectId).data.members[request.auth.uid]
        : null;
    }

    function canManageProject(projectId) {
      return isAdmin()
        || (isProjectMember(projectId) && (memberRole(projectId) in ["admin", "manager"]));
    }

    // Valida os 4 status permitidos para um projeto
    function isValidStatus(data) {
      return data.status in ["backlog", "andamento", "revisao", "concluido"];
    }

    // Valida campos obrigatórios ao criar um projeto
    function hasRequiredProjectFields(data) {
      return data.keys().hasAll([
        'title', 'status', 'phase', 'tags', 'members',
        'createdBy', 'createdAt', 'updatedBy', 'updatedAt', 'version'
      ]);
    }

    // Valida campos obrigatórios ao criar um documento
    function hasRequiredDocFields(data) {
      return data.keys().hasAll(['title', 'content', 'projectId', 'version']);
    }

    match /users/{uid} {
      allow create: if signedIn() && request.auth.uid == uid;

      allow read: if isAdmin() || (signedIn() && request.auth.uid == uid);

      allow update: if isAdmin()
        || (signedIn()
            && request.auth.uid == uid
            && !( "role" in request.resource.data.diff(resource.data).changedKeys() )
          );

      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      // Criação: validar campos obrigatórios, status válido e membro criador
      allow create: if signedIn()
        && hasRequiredProjectFields(request.resource.data)
        && isValidStatus(request.resource.data)
        && request.resource.data.members[request.auth.uid] == "admin"
        && request.resource.data.createdBy == request.auth.uid;

      allow read: if isProjectMember(projectId);

      // Atualização: não permite alterar createdBy nem createdAt
      allow update: if canManageProject(projectId)
        && isValidStatus(request.resource.data)
        && !( "createdBy" in request.resource.data.diff(resource.data).changedKeys() )
        && !( "createdAt" in request.resource.data.diff(resource.data).changedKeys() );

      allow delete: if isAdmin();

      match /docs/{docId} {
        // Criação: validar campos obrigatórios do documento
        allow read: if isProjectMember(projectId);
        allow create: if isProjectMember(projectId)
          && hasRequiredDocFields(request.resource.data)
          && request.resource.data.projectId == projectId;
        allow update: if isProjectMember(projectId);
        allow delete: if canManageProject(projectId);
      }

      // Histórico: imutável após criação (apenas admins podem deletar em emergência)
      match /history/{entryId} {
        allow read:   if isProjectMember(projectId);
        allow create: if isProjectMember(projectId);
        allow update: if false;  // histórico nunca é editado
        allow delete: if isAdmin();
      }

      match /exports/{exportId} {
        allow read: if isProjectMember(projectId);
        allow create: if isProjectMember(projectId);
        allow update, delete: if isAdmin();
      }

    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

